      },
      {
        "name": "totalAmount",
        "type": "number",
        "required": true,
        "description": "Total amount of the order"
      },
      {
        "name": "status",
        "type": "string",
        "required": true,
        "description": "Current status of the order"
      }
    ],
    "relationships": [
      {
        "entity": "User",
        "type": "manyToOne",
        "description": "Order belongs to a user"
      }
    ]
  }
