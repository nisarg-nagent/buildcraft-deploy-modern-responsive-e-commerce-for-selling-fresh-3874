  {
    "name": "Order",
    "description": "Represents a purchase order placed by a user.",
    "attributes": [
      {
        "name": "orderId",
        "type": "string",
        "required": true,
        "description": "Unique identifier for the order"
      },
      {
        "name": "userId",
        "type": "reference",
        "required": true,
        "description": "User who placed the order"
      },
      {
