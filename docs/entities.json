[
  {
    "name": "Product",
    "description": "Represents a product available in the store, such as a vegetable or fruit.",
    "attributes": [
      {
        "name": "productId",
        "type": "string",
        "required": true,
        "description": "Unique identifier for the product"
      },
      {
        "name": "name",
        "type": "string",
        "required": true,
        "description": "Name of the product"
      },
      {
        "name": "category",
        "type": "reference",
        "required": true,
        "description": "Category the product belongs to"
      },
      {
        "name": "description",
        "type": "string",
        "required": false,
        "description": "Detailed description of the product"
      },
      {
        "name": "price",
        "type": "number",
        "required": true,
        "description": "Price of the product"
      },
      {
        "name": "availability",
        "type": "boolean",
        "required": true,
        "description": "Availability status of the product"
      },
      {
        "name": "imageUrl",
        "type": "string",
        "required": false,
        "description": "Image URL of the product"
      }
    ],
    "relationships": [
      {
        "entity": "Category",
        "type": "manyToOne",
        "description": "A product belongs to a category"
      }
    ]
  },
  {
    "name": "Category",
    "description": "Represents a category of products.",
    "attributes": [
      {
        "name": "categoryId",
        "type": "string",
        "required": true,
        "description": "Unique identifier for the category"
      },
      {
        "name": "name",
        "type": "string",
        "required": true,
        "description": "Name of the category"
      }
    ],
    "relationships": [
      {
        "entity": "Product",
        "type": "oneToMany",
        "description": "A category can have many products"
      }
    ]
  },
  {
